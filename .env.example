# ============================================================
# Hu-Mate Assist — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Telegram (CMUHumateBot) ──────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Target chat that receives error alerts (optional override)
TELEGRAM_CHAT_ID=8704682336

# ── OpenWebUI / AI Backend ───────────────────────────────────
OPENWEBUI_API_URL=https://your-openwebui-host/api/chat/completions
OPENWEBUI_API_KEY=your_openwebui_api_key_here

# AI model name (default: hu-mate)
MODEL_NAME=hu-mate
